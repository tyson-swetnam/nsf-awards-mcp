# Docker build context optimization
# Exclude files and directories that shouldn't be copied to Docker context

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.node_repl_history

# Build outputs (will be generated during build)
build/
dist/

# Development files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Documentation (keep essential docs)
README.md
!INSTALL.md
!USAGE.md
docs/
*.md
!CLAUDE.md

# Test files
tests/
test/
__tests__/
coverage/
.nyc_output/
jest.config.js
*.test.ts
*.test.js
*.spec.ts
*.spec.js

# Linting and formatting
.eslintrc*
.prettierrc*
.editorconfig

# TypeScript config (keep for build)
!tsconfig.json

# Environment and secrets
.env
.env.*
!.env.example
secrets/
*.key
*.pem
*.p12
*.crt

# Logs
logs/
*.log

# Runtime and cache
.cache/
tmp/
temp/
.tmp/

# Development scripts
scripts/dev/
examples/
quickstart.sh

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore

# Backup files
*.bak
*.backup
*.orig

# IDE and editor files
.vscode/
.idea/
*.sublime-*
.brackets.json

# Mac files
.AppleDouble
.LSOverride

# Windows files
Desktop.ini
$RECYCLE.BIN/

# Linux files
*~

# Local configuration overrides
.claude/settings.local.json
mcp-config.json

# Go files (for future migration, currently not needed)
go.mod
go.sum
go/
*.go

# Python files (not applicable but good practice)
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.env/

# Package manager lock files (keep npm lock)
yarn.lock
pnpm-lock.yaml
!package-lock.json

# Misc
*.tar.gz
*.zip
*.rar